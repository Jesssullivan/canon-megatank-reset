# direnv configuration for canon-megatank-reset
# Usage: direnv allow

# Load the Nix devShell from flake.nix.
use flake

# Add first-party helpers to PATH.
if [ -d scripts ]; then
  PATH_add scripts
fi

load_sops_dotenv_if_exists() {
  local file="$1"
  [ -f "$file" ] || return 0
  watch_file "$file"
  if ! command -v sops >/dev/null 2>&1; then
    echo "canon-megatank-reset direnv: $file exists, but sops is not on PATH" >&2
    return 0
  fi
  dotenv <(sops --decrypt --output-type dotenv "$file")
}

# Operator-wide env first; repo-local env can override below.
dotenv_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/tinyland/canon-megatank-reset/env"
load_sops_dotenv_if_exists "$HOME/.config/tinyland/canon-megatank-reset/env.sops"

# Repo-local env. Keep secret-bearing files untracked.
dotenv_if_exists .env
dotenv_if_exists .env.local
load_sops_dotenv_if_exists .env.sops

if [ -f .envrc.local ]; then
  source_env .envrc.local
fi

# Reload direnv when these change.
watch_file flake.nix
watch_file flake.lock
watch_file pyproject.toml

# The capture host (mbp-13) ansible target. Override in .envrc.local if needed.
export CMR_CAPTURE_HOST="${CMR_CAPTURE_HOST:-mbp-13}"
