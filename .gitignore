# Environment files
.env
.env.local
.env.*.local
.envrc.local
.env.sops
.env.sops.*
!.env.example

# direnv + Nix
.direnv/
result
result-*

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
.ruff_cache/
.mypy_cache/
.hypothesis/
dist/
build/
*.egg-info/

# AI/LLM tooling (CLAUDE.md and AGENTS.md are tracked house contracts)
.claude/
.serena/
.aider*

# Local ephemeral state
.tmp/
.worktrees/
.huskycat/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# ─── Reverse-engineering artifacts — NEVER commit (no binary redistribution) ───
# Vendor binaries (Canon Service Tool, WICReset, firmware blobs) and the Ghidra
# project DB stay local. Only our own scripts + curated findings are tracked.
.ghidra-work/
*.exe
*.bin
*.dmg
*.zip
*.iso
decoded.asc
decoded.bin
firmware.bin

# Capture working dirs. Committed fixtures under captures/ are force-added.
canon-tool-staging/
/tmp-captures/
*.pcapng
*.pcap
!captures/*.pcapng.gz
# Probe/capture run outputs are REPRODUCIBLE from the tool — never publish them
# (raw dumps carry device identifiers; the curated findings live in docs/).
/artifacts/

# Rendered diagrams — sources (docs/diagrams/*.{mmd,dot}) are SSOT; SVG/PNG are
# build artifacts from `just diagrams`.
docs/diagrams/*.svg
docs/diagrams/*.png

# LaTeX paper build intermediates (the .pdf is committed by build-paper.yml on
# main; the .tex/.bib/.cls/.bst/.sty sources are tracked). Ignore stray aux files
# from a local `tectonic --keep-intermediates` run.
docs/paper/*.aux
docs/paper/*.bbl
docs/paper/*.blg
docs/paper/*.log
docs/paper/*.out
docs/paper/*.synctex.gz

# MkDocs (Material) build output + cache
site/
.cache/
